# Supabase is required only once backend integration begins.
# Leave these blank to keep the app in local/mock mode during early development.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional web override. Origins are normalized to /onboarding/sign-in;
# a complete callback is preferred for hosted browser UAT.
EXPO_PUBLIC_AUTH_REDIRECT_URL=https://preview.example.com/onboarding/sign-in

# PostHog should be optional and environment-gated.
# The app should still run when analytics variables are absent.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=

# Sentry should be optional and environment-gated.
# The app should still run when crash-reporting variables are absent.
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Public safety/legal links for TestFlight and in-app policy surfaces.
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://yourdomain.com/privacy
EXPO_PUBLIC_TERMS_URL=https://yourdomain.com/terms
EXPO_PUBLIC_COMMUNITY_STANDARDS_URL=https://yourdomain.com/community
EXPO_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com
EXPO_PUBLIC_SUPPORT_URL=https://yourdomain.com/support
EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://yourdomain.com/delete

# Never expose Supabase service-role keys in the mobile app.
